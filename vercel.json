{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/About",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/Affiliate-Disclosure",
      "destination": "/affiliate-disclosure",
      "permanent": true
    },
    {
      "source": "/Blog",
      "destination": "/blog",
      "permanent": true
    },
    {
      "source": "/Contact",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/Editorial-Policy",
      "destination": "/editorial-policy",
      "permanent": true
    },
    {
      "source": "/Privacy",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/Resources",
      "destination": "/resources",
      "permanent": true
    },
    {
      "source": "/Terms",
      "destination": "/terms",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "eco-tiny-living-site.vercel.app"
        }
      ],
      "destination": "https://ecotinylivinghub.thrwds.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "eco-tiny-living-site-aaron-s-evans-projects.vercel.app"
        }
      ],
      "destination": "https://ecotinylivinghub.thrwds.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "eco-tiny-living-site-git-main-aaron-s-evans-projects.vercel.app"
        }
      ],
      "destination": "https://ecotinylivinghub.thrwds.com/:path*",
      "permanent": true
    }
  ]
}
