{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "images": {
    "sizes": [320, 480, 640, 800, 960, 1200],
    "localPatterns": [{ "pathname": "^/assets/.*$", "search": "" }],
    "qualities": [75],
    "formats": ["image/webp"],
    "minimumCacheTTL": 86400,
    "dangerouslyAllowSVG": false,
    "contentSecurityPolicy": "script-src 'none'; frame-src 'none'; sandbox;",
    "contentDispositionType": "inline"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-Frame-Options", "value": "DENY" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://choosebettertech.us22.list-manage.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https://www.google-analytics.com https://*.google-analytics.com; connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com; media-src 'self'; manifest-src 'self'; worker-src 'self' blob:; upgrade-insecure-requests"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/About", "destination": "/about", "permanent": true },
    { "source": "/Affiliate-Disclosure", "destination": "/affiliate-disclosure", "permanent": true },
    { "source": "/Blog", "destination": "/blog", "permanent": true },
    { "source": "/Contact", "destination": "/contact", "permanent": true },
    { "source": "/Editorial-Policy", "destination": "/editorial-policy", "permanent": true },
    { "source": "/Privacy", "destination": "/privacy", "permanent": true },
    { "source": "/Resources", "destination": "/resources", "permanent": true },
    { "source": "/Terms", "destination": "/terms", "permanent": true },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "ecotinylivinghub.thrwds.com" }],
      "destination": "https://ecotinylivinghub.com/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "ecotinylivinghub.thrwds.com" }],
      "destination": "https://ecotinylivinghub.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "eco-tiny-living-site.vercel.app" }],
      "destination": "https://ecotinylivinghub.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "eco-tiny-living-site-aaron-s-evans-projects.vercel.app" }],
      "destination": "https://ecotinylivinghub.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "eco-tiny-living-site-git-main-aaron-s-evans-projects.vercel.app" }],
      "destination": "https://ecotinylivinghub.com/:path*",
      "permanent": true
    }
  ]
}
